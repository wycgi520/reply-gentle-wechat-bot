# Server
PORT=3000
PUBLIC_BASE_URL=https://your-domain.example.com

# WeChat Official Account
WECHAT_TOKEN=replace-with-your-wechat-server-token
WECHAT_APP_ID=replace-with-your-appid
WECHAT_APP_SECRET=replace-with-your-appsecret

# 302.AI
AI302_API_KEY=replace-with-your-302-ai-key
AI302_MODEL=deepseek-chat
AI302_TIMEOUT_MS=4200
AI302_MOCK=false

# Local MVP storage
DATA_DIR=./data
